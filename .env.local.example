# Copy to .env.local — restart: npm run dev

# Local MongoDB (requires mongod running) OR MongoDB Atlas:
# MONGODB_URI=mongodb://127.0.0.1:27017/venturebank
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/venturebank?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/venturebank

JWT_SECRET=your-long-random-secret-minimum-32-characters
JWT_EXPIRES_IN=7d
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VentureBank

ADMIN_WHITELIST_EMAILS=okochaaugustine158@gmail.com,admin2@venturebank.com
ADMIN_PASSWORD=YourSecureAdminPassword123!

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=okochaaugustine158@gmail.com
SMTP_PASS=your-gmail-app-password-no-spaces
SMTP_FROM="VentureBank" <okochaaugustine158@gmail.com>

# Paystack
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=your-paystack-public-key
